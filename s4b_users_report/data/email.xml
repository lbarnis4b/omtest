<?xml version="1.0" encoding="UTF-8"?>
<openerp>
    <data noupdate="0">
        <record model="ir.cron" id="users_report_cronjob">
            <field name="name">Licensed users report</field>
            <field name="interval_number">1</field>
            <field name="interval_type">months</field>
            <field name="numbercall">-1</field>
            <field name="nextcall" eval="(DateTime.now() + relativedelta(months=1,day=5)).strftime('%Y-%m-%d 00:02:00')" />
            <field name="doall" eval="False"/>
            <field name="model_id" ref="base.model_res_company"/>
			<field name="state">code</field>
            <field name="code">model.licensed_users_report()</field>	
        </record>

        <record id="users_report" model="mail.template">
            <field name="name">Licensed users report</field>
            <field name="model_id" ref="base.model_res_company"/>
            <field name="subject"><![CDATA[Users report]]></field>
            <field name="body_html"><![CDATA[]]></field>
			<field name="auto_delete" eval="False"/>
        </record>
    </data>
</openerp>
